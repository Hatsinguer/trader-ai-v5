# Trader AI v5 — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.

# Claude API — recomendado para comentários de IA em ai_commentary()
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# OpenAI — opcional, usado como fallback legado se ANTHROPIC_API_KEY não estiver definida
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# Brapi — opcional. Sem token usa o plano gratuito (com limite de requisições por hora)
# Obtenha em: https://brapi.dev/
# BRAPI_TOKEN=xxxxxxxxxxxxxxxx

# Configurações padrão da ferramenta (opcional)
# TRADER_AI_PERFIL_DEFAULT=Moderado
# TRADER_AI_PERIODO_DEFAULT=1y
